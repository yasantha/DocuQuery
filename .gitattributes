# Normalize line endings: detect text automatically, default to LF in the repo.
* text=auto eol=lf

# Windows batch files need CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# The Maven wrapper shell script runs on Linux (Docker build) — must be LF.
mvnw text eol=lf

# Binaries.
*.jar binary
*.pdf binary
